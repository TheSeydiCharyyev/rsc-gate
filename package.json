{
  "name": "rsc-gate",
  "version": "0.3.0",
  "description": "Catch React Server Component boundary bugs before next build — non-serializable props, server-only leaks, and accidental client bundling — in CI and your editor.",
  "type": "module",
  "bin": {
    "rsc-gate": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "react",
    "rsc",
    "react-server-components",
    "nextjs",
    "app-router",
    "use-client",
    "serialization",
    "server-only",
    "ci",
    "lint"
  ],
  "author": "Seydi Charyyev",
  "license": "MIT",
  "homepage": "https://github.com/TheSeydiCharyyev/rsc-gate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheSeydiCharyyev/rsc-gate.git"
  },
  "bugs": {
    "url": "https://github.com/TheSeydiCharyyev/rsc-gate/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "vitest": "^4.1.8"
  }
}
